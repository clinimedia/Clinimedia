# CliniMedia contact form · SMTP environment variables
# Copy to .env (gitignored) for local dev, or set these in
# Vercel → Project → Settings → Environment Variables for production.

# ── Required ───────────────────────────────────────────────
SMTP_HOST=         # e.g. smtp.zoho.com / smtp.gmail.com / smtp.office365.com
SMTP_PORT=         # 587 (STARTTLS) or 465 (SSL)
SMTP_USER=         # the SMTP login user (usually the from-address mailbox)
SMTP_PASS=         # the SMTP password / app password

# ── Optional overrides ─────────────────────────────────────
CONTACT_TO=info@clinimedia.ca           # destination for form submissions
CONTACT_FROM=                            # defaults to SMTP_USER if unset
CONTACT_REPLY_TO=                        # defaults to the submitter's email
